# Copy this file to .env and fill in your real key.

# ── Provider 選擇 ──────────────────────────────
# claude = 用 Anthropic API（預設）
# openai = 用 OpenAI 兼容端點（真 OpenAI / vLLM / Ollama / LiteLLM）
LLM_PROVIDER=claude

# ── Claude（LLM_PROVIDER=claude 時用） ────────
# 取得方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI-兼容（LLM_PROVIDER=openai 時用） ────
# 自架 vLLM 範例：
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=dummy
# OPENAI_MODEL=gemma-4
#
# 真 OpenAI：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Server port（預設 3000） ──────────────────
# PORT=3000
