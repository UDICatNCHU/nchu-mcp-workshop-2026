# Copy to .env and fill in your real key.

# ── Provider 選擇 ──────────────────────────────
# claude = 用 Anthropic API（預設）
# openai = 用 OpenAI 兼容端點
LLM_PROVIDER=claude

# ── Claude（LLM_PROVIDER=claude 時用） ────────
# 取得方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# 模型可選：claude-haiku-4-5（便宜快速，推薦）/ claude-sonnet-4-5（更聰明貴一些）
CLAUDE_MODEL=claude-haiku-4-5

# ── OpenAI-兼容（LLM_PROVIDER=openai 時用） ────
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=dummy
# OPENAI_MODEL=gemma-4

# ── Server port（預設 3001，避開 mini-project 的 3000） ──
# PORT=3001
